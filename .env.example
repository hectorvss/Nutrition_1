# App
APP_URL=http://localhost:3000

# Supabase — Backend (Node.js, no VITE_ prefix)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Supabase — Frontend (Vite injects these into the client bundle)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
# WARNING: VITE_SUPABASE_SERVICE_ROLE_KEY is exposed to the browser. Only include
# if your RLS policies are correctly configured and you understand the risks.
VITE_SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Backend server port
PORT=3006

# Stripe (required for billing)
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Security secrets (generate random strings for production)
CRON_SECRET=your_random_cron_secret
SETUP_SECRET=your_random_setup_secret
FRONTEND_URL=https://your-domain.vercel.app
